{
  "name": "@zrosenbauer/fastify-prisma",
  "version": "7.0.1",
  "description": "Fastify Prisma plugin connection to share the same connection across your entire server.",
  "keywords": [
    "fastify",
    "fastify-plugin",
    "plugin",
    "prisma"
  ],
  "homepage": "https://github.com/zrosenbauer/fastify-prisma#readme",
  "bugs": {
    "url": "https://github.com/zrosenbauer/fastify-prisma/issues"
  },
  "license": "MIT",
  "author": "Zac Rosenbauer <me@zrosenbauer.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zrosenbauer/fastify-prisma.git"
  },
  "files": [
    "README.md",
    "package.json",
    "dist/**/*"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prebuild": "pnpm clean:dist",
    "build": "pnpm prebuild && pkgroll",
    "clean": "pnpm clean:dist && pnpm clean:cache",
    "clean:cache": "rimraf --glob \"**/node_modules\"",
    "clean:dist": "rimraf --glob \"./dist\"",
    "prisma:generate": "prisma generate --schema ./tests/prisma/schema.prisma",
    "analyze:fmt": "oxfmt --check",
    "analyze:lint": "oxlint",
    "analyze:ci": "oxlint && oxfmt --check",
    "analyze:types": "tsc --noEmit",
    "fix": "oxlint --fix && oxfmt",
    "test": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tsconfig/recommended": "^1.0.13",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.8.5",
    "husky": "^9.1.7",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "pkgroll": "^2.27.0",
    "prisma": "7.8.0",
    "rimraf": "^6.1.3",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "fastify": "5.x"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  }
}
